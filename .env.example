# Proxmox connection
PROXMOX_HOST=https://proxmox.example.com:8006
PROXMOX_TOKEN_ID=root@pam!provisionops
PROXMOX_TOKEN_SECRET=your-token-secret
PROXMOX_NODE=proxmox

# Set USE_MOCK=true to run without a real Proxmox
USE_MOCK=true

# App config
APP_SECRET_KEY=change-me-to-a-random-string
APP_DEBUG=true
